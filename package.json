{
  "name": "prisma-to-ecto",
  "version": "0.0.2",
  "description": "Convert Prisma schema to Ecto schema with migrations",
  "main": "dist/index.js",
  "bin": {
    "prisma-to-ecto": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:test": "tsc -p tsconfig.test.json",
    "start": "node dist/index.js",
    "test": "npm run build:test && node dist-test/test/run_tests.js",
    "convert": "npm run build && node dist/index.js convert",
    "convert:watch": "tsc --watch",
    "bnp": "npm run build && npm publish",
    "bnl": "npm run build && npm link && prisma-to-ecto convert",
    "prepublishOnly": "npm run build && npm test"
  },
  "homepage": "https://github.com/iamkanishka/prisma-to-ecto/blob/master/readme.md",
  "keywords": [
    "Ecto",
    "Prisma",
    "Phoenix Framework",
    "Elixir",
    "Prisma-to-Ecto",
    "schema conversion"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamkanishka/prisma-to-ecto"
  },
  "author": "Kanishka Naik",
  "bugs": {
    "url": "https://github.com/iamkanishka/prisma-to-ecto/issues",
    "email": "kanishkabc123@gmail.com"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.4.0"
  }
}
